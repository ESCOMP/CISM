#[]
#dimensions:    time, level, y1, x1
#units:           The documentation will complain if units have LaTeX characters like ^
#long_name:     
#data:          
#factor:        

# Note on scales: CISM uses SI units (m, kg, s) for most calculations.
# For velocities, melt rates, and similar quantities, units of yr^(-1) are more intuitive than s^(-1).
# Thus, many I/O variables have a time unit of yr^(-1) or yr.
# The units are converted to s in the code by using scyr or 1/scyr as a scale factor.
# Previous code versions used scale factors such as scale_uvel, scale_acab, etc. These have been removed.

# setup for code generator
[VARSET]
# prefix of the generated module
name:     glide
# f90 type containing all necessary data
datatype: glide_global_type   
# module where type is defined
datamod:  glide_types
# path to parallel derived type
datapath: data

[x0]
dimensions:    x0
units:         meter
long_name:     Cartesian x-coordinate, velocity grid
axis:          X
data:          data%general%x0
dimlen:        model%parallel%global_ewn-1
load:          1

[y0]
dimensions:    y0
units:         meter
long_name:     Cartesian y-coordinate, velocity grid
axis:          Y
data:          data%general%y0
dimlen:        model%parallel%global_nsn-1
load:          1

[x1]
dimensions:    x1
units:         meter
long_name:     Cartesian x-coordinate
axis:          X
data:          data%general%x1
dimlen:        model%parallel%global_ewn
load:          1

[y1]
dimensions:    y1
units:         meter
long_name:     Cartesian y-coordinate
axis:          Y
data:          data%general%y1
dimlen:        model%parallel%global_nsn
load:          1

[level]
dimensions:    level
units:         1
long_name:     sigma layers
standard_name: land_ice_sigma_coordinate
positive:      down
dimlen:        model%general%upn

[staglevel]
dimensions:    staglevel
units:         1
long_name:     stag sigma layers
standard_name: land_ice_stag_sigma_coordinate
positive:      down
dimlen:        model%general%upn-1

[stagwbndlevel]
dimensions:    stagwbndlevel
units:         1
long_name:     stag sigma layers with boundaries
standard_name: land_ice_stag_sigma_coordinate_with_bnd
positive:      down
dimlen:        model%general%upn+1

[zocn]
dimensions:    zocn
units:         meter
long_name:     ocean_z_coordinate
data:          data%ocean_data%zocn
positive:      up
dimlen:        model%ocean_data%nzocn

[zatm]
dimensions:    zatm
units:         meter
long_name:     atmosphere_z_coordinate
data:          data%climate%zatm
positive:      up
dimlen:        model%climate%nzatm

[glacierid]
dimensions:    glacierid
units:         1
long_name:     glacier_id_coordinate
dimlen:        model%glacier%nglacier

[lithoz]
dimensions:    lithoz
units:         meter
long_name:     vertical coordinate of lithosphere layer
dimlen:        model%lithot%nlayer

[axis]
dimensions:    axis
units:         1
long_name:     axis coordinate for calvingMIP output
dimlen:        model%calving%naxis

[lat]
dimensions:    time, y1, x1
units:         degreeN
standard_name: latitude
long_name:     latitude
data:          data%general%lat
load:          1

[lon]
dimensions:    time, y1, x1
units:         degreeE
standard_name: longitude
long_name:     longitude
data:          data%general%lon
load:          1

[cell_area]
dimensions:    time, y1, x1
units:         meter2
long_name:     cell area of cism grid
data:          data%geometry%cell_area
load:          1

[relx]
dimensions:    time, y1, x1
units:         meter
long_name:     relaxed bedrock topography
data:          data%isostasy%relx
load:          1

[load]
dimensions:    time, y1, x1
units:         meter
long_name:     bedrock deflection from applied load
data:          data%isostasy%load
load:          1

[eus]
dimensions:    time
units:         meter
long_name:     global average sea level
data:          data%climate%eus
standard_name: global_average_sea_level_change

[uflx]
dimensions:    time, y0, x0
units:         meter2/year
long_name:     flux in x direction (NOTE: Glide only)
data:          data%velocity%uflx
factor:        scyr

[vflx]
dimensions:    time, y0, x0
units:         meter2/year
long_name:     flux in x direction (NOTE: Glide only)
data:          data%velocity%vflx
factor:        scyr

[diffu]
dimensions:    time, y0, x0
units:         meter2/year
long_name:     apparent diffusivity
data:          data%velocity%diffu
factor:        scyr

[btrc]
dimensions:    time, y0, x0
units:         meter/pascal/year
long_name:     basal slip coefficient
data:          data%velocity%btrc
factor:        scyr

[soft]
dimensions:    time, y0, x0
units:         meter/pascal/year
long_name:     bed softness parameter
data:          data%velocity%bed_softness
factor:        scyr
load:          1

[beta]
dimensions:    time, y0, x0
units:         Pa yr/m  
long_name:     higher-order bed stress coefficient
data:          data%velocity%beta
factor:        1.0/scyr
load:          1

#WHL - added unstagbeta, which lives on the unstaggered ice grid
#      (unlike beta, which lives on the staggered velocity grid)
[unstagbeta]
dimensions:    time, y1, x1
units:         Pa yr/m  
long_name:     higher-order bed stress coefficient on the unstaggered grid (NOTE: this will overwrite beta if both are input)
data:          data%velocity%unstagbeta
factor:        1.0/scyr
load:          1

#WHL - beta_internal is derived from beta, but may be weighted by f_ground or otherwise adjusted
#      It can be written to history files but should not be read from restart files
[beta_internal]
dimensions:    time, y0, x0
units:         Pa yr/m
long_name:     weighted higher-order bed stress coefficient
data:          data%velocity%beta_internal
factor:        1.0/scyr

[tauf]
dimensions:    time, y0, x0
units:         Pa
long_name:     higher-order basal yield stress
data:          data%basal_physics%mintauf
load:          1

[btractx]
dimensions:    time, y0, x0
units:         Pa
long_name:     basal traction (x-direction comp)
data:          data%stress%btractx(:,:)
load:          1

[btracty]
dimensions:    time, y0, x0
units:         Pa
long_name:     basal traction (y-direction comp)
data:          data%stress%btracty(:,:)
load:          1

[btract]
dimensions:    time, y0, x0
units:         Pa
long_name:     basal traction (magnitude)
data:          data%stress%btract(:,:)
load:          1

[btractx_extend]
dimensions:    time, y1, x1
units:         Pa
long_name:     basal traction (x-direction comp)
data:          data%stress%btractx_extend(:,:)
load:          1

[btracty_extend]
dimensions:    time, y1, x1
units:         Pa
long_name:     basal traction (y-direction comp)
data:          data%stress%btracty_extend(:,:)
load:          1

[usfc]
dimensions:    time, y0, x0
units:         meter/year
long_name:     surface velocity in x direction
data:          data%velocity%uvel(1,1:data%general%ewn-1,1:data%general%nsn-1)
factor:        scyr
standard_name: land_ice_surface_x_velocity

[vsfc]
dimensions:    time, y0, x0
units:         meter/year
long_name:     surface velocity in y direction
data:          data%velocity%vvel(1,1:data%general%ewn-1,1:data%general%nsn-1)
factor:        scyr
standard_name: land_ice_surface_y_velocity

[wsfc]
dimensions:    time, y1, x1
units:         meter/year
long_name:     surface velocity in z direction
data:          data%velocity%wvel(1,1:data%general%ewn,1:data%general%nsn)
factor:        scyr
standard_name: land_ice_surface_z_velocity

[ubas]
dimensions:    time, y0, x0
units:         meter/year
long_name:     basal slip velocity in x direction
data:          data%velocity%uvel(data%general%upn,1:data%general%ewn-1,1:data%general%nsn-1)
factor:        scyr
standard_name: land_ice_basal_x_velocity

[vbas]
dimensions:    time, y0, x0
units:         meter/year
long_name:     basal slip velocity in y direction
data:          data%velocity%vvel(data%general%upn,1:data%general%ewn-1,1:data%general%nsn-1)
factor:        scyr
standard_name: land_ice_basal_y_velocity

[wbas]
dimensions:    time, y1, x1
units:         meter/year
long_name:     basal velocity in z direction
data:          data%velocity%wvel(data%general%upn,1:data%general%ewn,1:data%general%nsn)
factor:        scyr
standard_name: land_ice_basal_z_velocity

[usfc_obs]
dimensions:    time, y0, x0
units:         meter/year
long_name:     observed surface velocity in x direction
data:          data%velocity%usfc_obs
factor:        scyr
standard_name: land_ice_surface_x_velocity_observed
load:          1

[vsfc_obs]
dimensions:    time, y0, x0
units:         meter/year
long_name:     observed surface velocity in y direction
data:          data%velocity%vsfc_obs
factor:        scyr
standard_name: land_ice_surface_y_velocity_observed
load:          1

[velo_sfc_obs]
dimensions:    time, y0, x0
units:         meter/year
long_name:     observed surface speed
data:          data%velocity%velo_sfc_obs
factor:        scyr
standard_name: land_ice_surface_speed_observed
load:          1

[bmlt_float]
dimensions:    time, y1, x1
units:         meter/year
long_name:     basal melt rate for floating ice
data:          data%basal_melt%bmlt_float
factor:        scyr
standard_name: floating_ice_basal_melt_rate
load:          0

[bmlt_float_external]
dimensions:    time, y1, x1
units:         meter/year
long_name:     external basal melt rate for floating ice
data:          data%basal_melt%bmlt_float_external
factor:        scyr
standard_name: floating_ice_basal_melt_rate_external
load:          1

[bmlt_float_anomaly]
dimensions:    time, y1, x1
units:         meter/year
long_name:     basal melt rate anomaly for floating ice
data:          data%basal_melt%bmlt_float_anomaly
factor:        scyr
standard_name: floating_ice_basal_melt_rate_anomaly
load:          1

[warm_ocean_mask]
dimensions:    time, y1, x1
units:         1
long_name:     warm ocean mask
data:          data%basal_melt%warm_ocean_mask
load:          1
type:          int

#WHL - Fields related to ISMIP6 ocean data

[basin_number]
dimensions:    time, y1, x1
units:         1
long_name:     basin_number
data:          data%ocean_data%basin_number
load:          1
type:          int

[deltaT_ocn]
dimensions:    time, y1, x1
units:         degrees K
long_name:     deltaT_ocn
data:          data%ocean_data%deltaT_ocn
load:          1

[thermal_forcing]
dimensions:    time, zocn, y1, x1
units:         degrees K
long_name:     thermal_forcing
data:          data%ocean_data%thermal_forcing(up,:,:)
load:          1

[thermal_forcing_lsrf]
dimensions:    time, y1, x1
units:         degrees K
long_name:     thermal_forcing at lower ice surface
data:          data%ocean_data%thermal_forcing_lsrf(:,:)

[flow_enhancement_factor]
dimensions:    time, y1, x1
units:         1
long_name:     flow enhancement factor
data:          data%temper%flow_enhancement_factor
load:          1

#WHL - Fields for a future MISOMIP option

[T_ambient]
dimensions:    time, y1, x1
units:         degree_Celsius
long_name:     ambient ocean temperature
data:          data%plume%T_ambient(1:data%general%ewn,1:data%general%nsn)
standard_name: ambient_ocean_temperature

[S_ambient]
dimensions:    time, y1, x1
units:         psu
long_name:     ambient ocean salinity
data:          data%plume%S_ambient(1:data%general%ewn,1:data%general%nsn)
standard_name: ambient ocean salinity

[taudx]
dimensions:    time, y0, x0
units:         Pa
long_name:     driving stress (x-direction comp)
data:          data%stress%taudx(:,:)
load:          1

[taudy]
dimensions:    time, y0, x0
units:         Pa
long_name:     driving stress (y-direction comp)
data:          data%stress%taudy(:,:)
load:          1

[taux]
dimensions:    time, y0, x0
units:         kilopascal
long_name:     basal shear stress in x direction (NOTE: Glide only)
data:          data%velocity%tau_x
factor:        1e-3

[tauy]
dimensions:    time, y0, x0
units:         kilopascal
long_name:     basal shear stress in y direction
data:          data%velocity%tau_y
factor:        1e-3

[tau_c]
dimensions:    time, y0, x0
units:         kilopascal
long_name:     yield stress for plastic sliding
data:          data%basal_physics%tau_c
factor:        1e-3

[thk]
dimensions:    time, y1, x1
units:         meter
long_name:     ice thickness
data:          data%geometry%thck
load:          1
standard_name: land_ice_thickness

[stagthk]
dimensions:    time, y0, x0
units:         meter
long_name:     staggered ice thickness
data:          data%geomderv%stagthck
standard_name: stag_land_ice_thickness
load:          0

[reference_thck]
dimensions:    time, y1, x1
units:         meter
long_name:     reference ice thickness
data:          data%geometry%reference_thck
load:          1

[usrf_obs]
dimensions:    time, y1, x1
units:         meter
long_name:     observed surface elevation
data:          data%geometry%usrf_obs
load:          1

[dthk_dt_obs]
dimensions:    time, y1, x1
units:         meter/year
long_name:     observed rate of ice thickness change
data:          data%geometry%dthck_dt_obs
factor:        scyr
load:          1

[dthk_dt_obs_basin]
dimensions:    time, y1, x1
units:         meter/year
long_name:     observed rate of ice thickness change, basin average
data:          data%geometry%dthck_dt_obs_basin
factor:        scyr
load:          1

[dthck_dt]
dimensions:    time, y1, x1
units:         meter/year
long_name:     rate of ice thickness change
data:          data%geometry%dthck_dt
factor:        scyr

[floating_thck_target]
dimensions:    time, y1, x1
units:         meter
long_name:     target thickness for floating ice
data:          data%inversion%floating_thck_target
load:          1

[grounded_thck_target]
dimensions:    time, y1, x1
units:         meter
long_name:     target thickness for grounded ice
data:          data%inversion%grounded_thck_target
load:          1

[land_thck_target]
dimensions:    time, y1, x1
units:         meter
long_name:     target thickness for land-grounded ice
data:          data%inversion%land_thck_target
load:          1

[marine_thck_target]
dimensions:    time, y1, x1
units:         meter
long_name:     target thickness for marine-grounded ice
data:          data%inversion%marine_thck_target
load:          1

[calving_thck]
dimensions:    time, y1, x1
units:         meter
long_name:     thickness of calving ice
data:          data%calving%calving_thck

[calving_rate]
dimensions:    time, y1, x1
units:         meter/year
long_name:     rate of mass loss by calving
data:          data%calving%calving_rate
average:       1

[calving_mask]
dimensions:    time, y1, x1
units:         1
long_name:     calving mask
data:          data%calving%calving_mask
load:          1
type:          int

[subgrid_calving_mask]
dimensions:    time, y1, x1
units:         1
long_name:     subgrid calving mask
data:          data%calving%subgrid_calving_mask
load:          1

[calving_lateral]
dimensions:    time, y1, x1
units:         meter/year
long_name:     lateral calving rate
data:          data%calving%lateral_rate
factor:        scyr

[effective_areafrac]
dimensions:    time, y1, x1
units:         1
long_name:     effective area fraction
data:          data%calving%effective_areafrac

[damage]
dimensions:    time, staglevel, y1, x1
units:         unitless [0,1]
long_name:     ice damage
data:          data%calving%damage(up,:,:)
load:          1

[area_factor]
dimensions:    time, y1, x1
units:         unitless
long_name:     area scale factor for stereographic map projection
data:          data%projection%stere%area_factor
  
[iarea]
dimensions:    time
units:         m2
long_name:     area covered by ice 
data:          data%geometry%iarea

[iareag]
dimensions:    time
units:         m2
long_name:     area covered by grounded ice 
data:          data%geometry%iareag

[iareaf]
dimensions:    time
units:         m2
long_name:     area covered by floating ice 
data:          data%geometry%iareaf

[ivol]
dimensions:    time
units:         m3
long_name:     ice volume
data:          data%geometry%ivol

[imass]
dimensions:    time
units:         kg
long_name:     ice mass
data:          data%geometry%imass

[imass_above_flotation]
dimensions:    time
units:         kg
long_name:     ice mass above flotation
data:          data%geometry%imass_above_flotation

[total_smb_flux]
dimensions:    time
units:         kg/s
long_name:     total surface mass balance flux
data:          data%geometry%total_smb_flux
average:       1

[total_bmb_flux]
dimensions:    time
units:         kg/s
long_name:     total basal mass balance flux
data:          data%geometry%total_bmb_flux
average:       1

[total_calving_flux]
dimensions:    time
units:         kg/s
long_name:     total calving mass balance flux
data:          data%geometry%total_calving_flux
average:       1

#calvingMIP output

[cf_radius]
dimensions:    time, axis
long_name:     calving-front radius
units:         km
data:          data%calving%cf_radius
type:          real
factor:        0.001

[cf_thck]
dimensions:    time, axis
long_name:     calving-front thickness
units:         m
data:          data%calving%cf_thck
type:          real

[cf_speed]
dimensions:    time, axis
long_name:     calving-front speed
units:         m/year
data:          data%calving%cf_speed
type:          real
factor:        scyr

[thkmask]
dimensions:    time, y1, x1
long_name:     mask
units:         1
data:          data%geometry%thkmask
type:          int
load:          1

[usurf]
dimensions:    time, y1, x1
units:         meter
long_name:     ice upper surface elevation
data:          data%geometry%usrf
load:          1
standard_name: surface_altitude

[lsurf]
dimensions:    time, y1, x1
units:         meter
long_name:     ice lower surface elevation
data:          data%geometry%lsrf

[topg]
dimensions:    time, y1, x1
units:         meter
long_name:     bedrock topography
data:          data%geometry%topg
load:          1
standard_name: bedrock_altitude

[topg_raised]
dimensions:    time, y1, x1
units:         meter
long_name:     raised version of bedrock topography
data:          data%geometry%topg_raised
load:          1
standard_name: bedrock_altitude_raised

[ice_domain_mask]
dimensions:    time, y1, x1
units:         1
long_name:     mask for where ice is potentially present and active
data:          data%general%ice_domain_mask
load:          1

[ice_mask]
dimensions:    time, y1, x1
units:         1
long_name:     mask for ice (1) or no ice (0)
data:          data%geometry%ice_mask
type:          int

[ice_mask_stag]
dimensions:    time, y0, x0
units:         1
long_name:     mask on staggered grid for ice (1) or no ice (0)
data:          data%geometry%ice_mask_stag
type:          int

[floating_mask]
dimensions:    time, y1, x1
units:         1
long_name:     mask for floating ice 
data:          data%geometry%floating_mask
type:          int

[grounded_mask]
dimensions:    time, y1, x1
units:         1
long_name:     mask for grounded ice
data:          data%geometry%grounded_mask
type:          int

[marine_connection_mask]
dimensions:    time, y1, x1
units:         1
long_name:     mask for marine_connected cells
data:          data%geometry%marine_connection_mask
type:          int

[ice_sheet_mask]
dimensions:    time, y1, x1
units:         1
long_name:     mask for ice sheet
data:          data%geometry%ice_sheet_mask
type:          int

[ice_cap_mask]
dimensions:    time, y1, x1
units:         1
long_name:     mask for ice caps
data:          data%geometry%ice_cap_mask
type:          int

[ice_fraction_retreat_mask]
dimensions:    time, y1, x1
units:         1
long_name:     real mask for forced ice retreat
data:          data%geometry%ice_fraction_retreat_mask
load:          1

[acab]
dimensions:    time, y1, x1
units:         meter/year ice
long_name:     accumulation, ablation rate
data:          data%climate%acab
factor:        scyr
standard_name: land_ice_surface_specific_mass_balance
load:          1

[acab_applied]
dimensions:    time, y1, x1
units:         meter/year
long_name:     applied accumulation, ablation rate
data:          data%climate%acab_applied
factor:        scyr
standard_name: land_ice_surface_specific_mass_balance_applied
average:       1

[overwrite_acab_mask]
dimensions:    time, y1, x1
units:         1
long_name:     cells where acab is overwritten
data:          data%climate%overwrite_acab_mask
standard_name: land_ice_overwrite_acab_mask
type:          int
load:          1

[smb]
dimensions:    time, y1, x1
units:         mm/year water equivalent
long_name:     surface mass balance
data:          data%climate%smb
standard_name: land_ice_surface_specific_mass_balance
load:          1

[smb_ref]
dimensions:    time, y1, x1
units:         mm/year water equivalent
long_name:     surface mass balance at reference elevation
data:          data%climate%smb_ref
standard_name: land_ice_surface_specific_mass_balance_reference
load:          1

[smb_gradz]
dimensions:    time, y1, x1
units:         mm/year water equivalent per m
long_name:     surface mass balance vertical gradient
data:          data%climate%smb_gradz
standard_name: land_ice_surface_specific_mass_balance_vertical_gradient
load:          1

[smb_anomaly]
dimensions:    time, y1, x1
units:         mm/year water equivalent
long_name:     surface mass balance anomaly
data:          data%climate%smb_anomaly
standard_name: land_ice_surface_specific_mass_balance_anomaly
load:          1

[smb_corrected]
dimensions:    time, y1, x1
units:         mm/year water equivalent
long_name:     corrected surface mass balance
data:          data%climate%smb_corrected
standard_name: land_ice_surface_specific_mass_balance_corrected

[smb_3d]
dimensions:    time, zatm, y1, x1
units:         mm/year water equivalent
long_name:     3D surface mass balance
data:          data%climate%smb_3d(up,:,:)
standard_name: land_ice_surface_specific_mass_balance_3d
load:          1

[smb_obs]
dimensions:    time, y1, x1
units:         mm/year water equivalent
long_name:     observed surface mass balance
data:          data%climate%smb_obs
load:          1

[smb_rgi]
dimensions:    time, y1, x1
units:         mm/year water equivalent
long_name:     surface mass balance at RGI date
data:          data%glacier%smb_rgi
load:          1

[smb_recent]
dimensions:    time, y1, x1
units:         mm/year water equivalent
long_name:     surface mass balance at recent date
data:          data%glacier%smb_recent
load:          1

[artm_ref]
dimensions:    time, y1, x1
units:         deg Celsius
long_name:     surface temperature at reference elevation
data:          data%climate%artm_ref
standard_name: land_ice_reference_surface_temperature
load:          1
read_once:     1

[artm_gradz]
dimensions:    time, y1, x1
units:         deg Celsius per m
long_name:     surface temperature vertical gradient
data:          data%climate%artm_gradz
standard_name: land_ice_surface_temperature_vertical_gradient
load:          1

[artm_anomaly]
dimensions:    time, y1, x1
units:         deg Celsius
long_name:     surface temperature anomaly
data:          data%climate%artm_anomaly
standard_name: land_ice_surface_temperature_anomaly
load:          1
read_once:     1

[artm_3d]
dimensions:    time, zatm, y1, x1
units:         deg Celsius
long_name:     3D surface temperature
data:          data%climate%artm_3d(up,:,:)
standard_name: land_ice_surface_temperature_3d
load:          1

[snow]
dimensions:    time, y1, x1
units:         mm/year water equivalent
long_name:     snowfall rate
data:          data%climate%snow
load:          1
read_once:     1

[snow_anomaly]
dimensions:    time, y1, x1
units:         mm/year water equivalent
long_name:     anomaly snowfall rate
data:          data%climate%snow_anomaly
load:          1
read_once:     1

[precip]
dimensions:    time, y1, x1
units:         mm/year water equivalent
long_name:     precipitation rate
data:          data%climate%precip
load:          1
read_once:     1

[precip_anomaly]
dimensions:    time, y1, x1
units:         mm/year water equivalent
long_name:     anomaly precipitation rate
data:          data%climate%precip_anomaly
load:          1
read_once:     1

[usrf_ref]
dimensions:    time, y1, x1
units:         m
long_name:     reference upper surface elevation for input forcing
data:          data%climate%usrf_ref
standard_name: land_ice_reference_surface_elevation
load:          1

[ablation]
dimensions:    time, y1, x1
units:         mm/year water equivalent
long_name:     ablation rate
data:          data%climate%ablation

[thck_target]
dimensions:    time, y1, x1
units:         m
long_name:     glacier thickness target
data:          data%glacier%thck_target

#WHL: Note sign convention: positive downward
[bheatflx]
dimensions:    time, y1, x1
units:         watt/meter2
long_name:     downward basal heat flux
data:          data%temper%bheatflx
load:          1

[bmlt]
dimensions:    time, y1, x1
units:         meter/year
long_name:     basal melt rate
data:          data%basal_melt%bmlt
factor:        scyr
standard_name: land_ice_basal_melt_rate
#average:       1

[bmlt_ground]
dimensions:    time, y1, x1
units:         meter/year
long_name:     basal melt rate for grounded ice
data:          data%basal_melt%bmlt_ground
factor:        scyr
standard_name: grounded_ice_basal_melt_rate

[bmlt_applied]
dimensions:    time, y1, x1
units:         meter/year
long_name:     applied basal melt rate
data:          data%basal_melt%bmlt_applied
factor:        scyr
standard_name: land_ice_basal_melt_rate_applied
average:       1

[bfricflx]
dimensions:    time, y1, x1
units:         watt/meter2
long_name:     basal friction heat flux
data:          data%temper%bfricflx
load:          1

[bhydroflx]
dimensions:    time, y1, x1
units:         watt/meter2
long_name:     basal heat flux from refreezing meltwater
data:          data%temper%bhydroflx
load:          1

[bwat]
dimensions:    time, y1, x1
units:         meter
long_name:     local basal water depth
data:          data%basal_hydro%bwat
load:          1

[bwat_diag]
dimensions:    time, y1, x1
units:         meter
long_name:     basal water depth diagnosed from flux routing
data:          data%basal_hydro%bwat_diag
load:          1

[bwatflx]
dimensions:    time, y1, x1
units:         meter/year
long_name:     basal water flux
factor:        scyr
data:          data%basal_hydro%bwatflx

[head]
dimensions:    time, y1, x1
units:         meter
long_name:     hydraulic head
data:          data%basal_hydro%head
factor:        1

[effecpress]
dimensions:    time, y1, x1
units:         Pa
long_name:     effective pressure
data:          data%basal_physics%effecpress

[f_effecpress_ocean_p]
dimensions:    time, y1, x1
units:         1
long_name:     effective pressure factor from ocean_p
data:          data%basal_physics%f_effecpress_ocean_p
load:          1

[c_space_factor]
dimensions:    time, y1, x1
units:         1
long_name:     spatial factor for basal shear stress
data:          data%basal_physics%c_space_factor
load:          1

[powerlaw_c]
dimensions:    time, y0, x0
units:         Pa (m/yr)**(-1/3)
long_name:     spatially varying C for powerlaw sliding, staggered grid
data:          data%basal_physics%powerlaw_c
load:          1

[coulomb_c]
dimensions:    time, y0, x0
units:         1
long_name:     spatially varying C for Coulomb sliding, staggered grid
data:          data%basal_physics%coulomb_c
load:          1

[coulomb_c_hi]
dimensions:    time, y0, x0
units:         1
long_name:     Coulomb_c value for high bed elevation
data:          data%basal_physics%coulomb_c_hi
load:          1

[coulomb_c_lo]
dimensions:    time, y0, x0
units:         1
long_name:     Coulomb_c value for low bed elevation
data:          data%basal_physics%coulomb_c_lo
load:          1

[artm]
dimensions:    time, y1, x1
units:         degree_Celsius
long_name:     annual mean air temperature
data:          data%climate%artm
standard_name: surface_air_temperature
cell_methods:  time: mean
load:          1

[btemp]
dimensions:    time, y1, x1
units:         degree_Celsius
long_name:     basal ice temperature
data:          data%temper%btemp
standard_name: land_ice_temperature

[btemp_ground]
dimensions:    time, y1, x1
units:         degree_Celsius
long_name:     basal ice temperature for grounded ice
data:          data%temper%btemp_ground
standard_name: land_ice_temperature_ground

[btemp_float]
dimensions:    time, y1, x1
units:         degree_Celsius
long_name:     basal ice temperature for floating ice
data:          data%temper%btemp_float
standard_name: land_ice_temperature_float

[dusrfdtm]
dimensions:    time, y1, x1
units:         meter/year
long_name:     rate of upper ice surface elevation change (NOTE: Glide only)
data:          data%geomderv%dusrfdtm
factor:        scyr

[dthckdtm]
dimensions:    time, y1,x1
units:         meter/year
long_name:     tendency of ice thickness (NOTE: Glide only)
data:          data%geomderv%dthckdtm
factor:        scyr

[uvel]
dimensions:    time, level, y0, x0
units:         meter/year
long_name:     ice velocity in x direction
data:          data%velocity%uvel(up,:,:)
factor:        scyr
standard_name: land_ice_x_velocity
load:          1

[vvel]
dimensions:    time, level, y0, x0
units:         meter/year
long_name:     ice velocity in y direction
data:          data%velocity%vvel(up,:,:)
factor:        scyr
standard_name: land_ice_y_velocity
load:          1

[uvel_extend]
dimensions:    time, level, y1, x1
units:         meter/year
long_name:     ice velocity in x direction (extended grid)
data:          data%velocity%uvel_extend(up,:,:)
factor:        scyr
standard_name: land_ice_x_velocity
load:          1

[vvel_extend]
dimensions:    time, level, y1, x1
units:         meter/year
long_name:     ice velocity in y direction (extended grid)
data:          data%velocity%vvel_extend(up,:,:)
factor:        scyr
standard_name: land_ice_y_velocity
load:          1

[uvel_2d]
dimensions:    time, y0, x0
units:         meter/year
long_name:     vertically averaged ice velocity in x direction
data:          data%velocity%uvel_2d(:,:)
factor:        scyr
standard_name: land_ice_x_velocity_2d
load:          1

[vvel_2d]
dimensions:    time, y0, x0
units:         meter/year
long_name:     vertically averaged ice velocity in y direction
data:          data%velocity%vvel_2d(:,:)
factor:        scyr
standard_name: land_ice_y_velocity_2d
load:          1

[uvel_2d_extend]
dimensions:    time, y1, x1
units:         meter/year
long_name:     vertically averaged ice velocity in x direction (extended grid)
data:          data%velocity%uvel_2d_extend(:,:)
factor:        scyr
standard_name: land_ice_x_velocity_2d
load:          1

[vvel_2d_extend]
dimensions:    time, y1, x1
units:         meter/year
long_name:     vertically averaged ice velocity in y direction (extended grid)
data:          data%velocity%vvel_2d_extend(:,:)
factor:        scyr
standard_name: land_ice_y_velocity_2d
load:          1

[uvel_mean]
dimensions:    time, y0, x0
units:         meter/year
long_name:     vertical mean ice velocity in x direction
data:          data%velocity%uvel_mean
factor:        scyr
standard_name: land_ice_vertical_mean_x_velocity

[vvel_mean]
dimensions:    time, y0, x0
units:         meter/year
long_name:     vertical mean ice velocity in y direction
data:          data%velocity%vvel_mean
factor:        scyr
standard_name: land_ice_vertical_mean_y_velocity

[resid_u]
dimensions:     time, level, y0, x0
units:          Pa/m          
long_name:      u component of residual Ax - b (NOTE: Glissade only)
data:           data%velocity%resid_u(up,:,:)

[resid_v]
dimensions:     time, level, y0, x0
units:          Pa/m          
long_name:      v component of residual Ax - b (NOTE: Glissade only)
data:           data%velocity%resid_v(up,:,:)

[rhs_u]
dimensions:     time, level, y0, x0
units:          Pa/m          
long_name:      u component of b in Ax = b
data:           data%velocity%rhs_u(up,:,:)

[rhs_v]
dimensions:     time, level, y0, x0
units:          Pa/m          
long_name:      v component of b in Ax = b
data:           data%velocity%rhs_v(up,:,:)

[kinbcmask]
dimensions:   time, y0, x0
units:        1
long_name:    Mask of locations where uvel, vvel value should be held constant
data:         data%velocity%kinbcmask(:,:)
type:         int
load:         1

[velnorm]
dimensions:    time, level, y0, x0
units:         meter/year
long_name:     Horizontal ice velocity magnitude
data:          data%velocity%velnorm(up,:,:)
factor:        scyr

[divu]
dimensions: time, y1, x1
units:      1/year
long_name:  horizontal divergence
data:       data%velocity%divu
factor:     scyr
load:       1

[shear]
dimensions: time, y1, x1
units:      1/year
long_name:  horizontal shear-stretch rate
data:       data%velocity%shear
factor:     scyr
load:       1

[eps_eff]
dimensions: time, staglevel, y1, x1
units:      1/year
long_name:  effective strain rate
data:       data%velocity%strain_rate%scalar(up,:,:)
factor:     scyr

[eps_xz]
dimensions: time, staglevel, y1, x1
units:      1/year
long_name:  xz component of strain rate tensor
data:       data%velocity%strain_rate%xz(up,:,:)
factor:     scyr

[eps_yz]
dimensions: time, staglevel, y1, x1
units:      1/year
long_name:  yz component of strain rate tensor
data:       data%velocity%strain_rate%yz(up,:,:)
factor:     scyr

[eps_xx]
dimensions: time, staglevel, y1, x1
units:      1/year
long_name:  xx component of strain rate tensor
data:       data%velocity%strain_rate%xx(up,:,:)
factor:     scyr

[eps_yy]
dimensions: time, staglevel, y1, x1
units:      1/year
long_name:  yy component of strain rate tensor
data:       data%velocity%strain_rate%yy(up,:,:)
factor:     scyr

[eps_xy]
dimensions: time, staglevel, y1, x1
units:      1/year
long_name:  xy component of strain rate tensor
data:       data%velocity%strain_rate%xy(up,:,:)
factor:     scyr

[eps_eigen1]
dimensions: time, y1, x1
units:      1/year
long_name:  first eigenvalue of horizontal strain rate tensor
data:       data%calving%eps_eigen1
factor:     scyr
load:       1

[eps_eigen2]
dimensions: time, y1, x1
units:      1/year
long_name:  second eigenvalue of horizontal strain rate tensor
data:       data%calving%eps_eigen2
factor:     scyr
load:       1

[tau_eff]
dimensions: time, staglevel, y1, x1
units:      Pa
long_name:  effective stress
data:       data%stress%tau%scalar(up,:,:)

[tau_xz]
dimensions: time, staglevel, y1, x1
units:      Pa
long_name:  xz component of deviatoric stress tensor
data:       data%stress%tau%xz(up,:,:)

[tau_yz]
dimensions: time, staglevel, y1, x1
units:      Pa
long_name:  yz component of deviatoric stress tensor
data:       data%stress%tau%yz(up,:,:)

[tau_xx]
dimensions: time, staglevel, y1, x1
units:      Pa
long_name:  xx component of deviatoric stress tensor
data:       data%stress%tau%xx(up,:,:)

[tau_yy]
dimensions: time, staglevel, y1, x1
units:      Pa
long_name:  yy component of deviatoric stress tensor
data:       data%stress%tau%yy(up,:,:)

[tau_xy]
dimensions: time, staglevel, y1, x1
units:      Pa
long_name:  xy component of deviatoric stress tensor
data:       data%stress%tau%xy(up,:,:)

[tau_eigen1]
dimensions: time, y1, x1
units:      Pa
long_name:  first eigenvalue of horizontal stress tensor
data:       data%calving%tau_eigen1
load:       1

[tau_eigen2]
dimensions: time, y1, x1
units:      Pa
long_name:  second eigenvalue of horizontal stress tensor
data:       data%calving%tau_eigen2
load:       1

[wvel]
dimensions:    time, level, y1, x1
units:         meter/year
long_name:     vertical ice velocity
data:          data%velocity%wvel(up,:,:)
factor:        scyr
load:          1

[wgrd]
dimensions:    time, level, y1, x1
units:         meter/year
long_name:     Vertical grid velocity 
data:          data%velocity%wgrd(up,:,:)
factor:        scyr
load:          1

[waterfrac]
dimensions:    time, staglevel, y1, x1
units:         unitless [0,1]
long_name:     internal water fraction
data:          data%temper%waterfrac(up,:,:)
load:          1

[enthalpy]
dimensions:    time, stagwbndlevel, y1, x1
units:         J/m3
long_name:     specific enthalpy
data:          data%temper%enthalpy(up,:,:)

[flwa]
dimensions:    time, level, y1, x1
units:         pascal**(-n) year**(-1)
long_name:     Pre-exponential flow law parameter
data:          data%temper%flwa(up,:,:)
factor:        scyr
load:          1

[flwastag]
dimensions:    time, staglevel, y1, x1
units:         pascal**(-n) year**(-1)
long_name:     Pre-exponential flow law parameter
data:          data%temper%flwa(up,:,:)
factor:        scyr
# hot=0 because we do not want the stag version to be in the hotvars definition. 
# The conversion to stag happens if needed in check_for_tempstag
# but we do want it loadable in case flwa is listed as hot.
load:          1

[efvs]
dimensions:    time, staglevel, y1, x1
units:         Pascal * years
long_name:     effective viscosity               
data:          data%stress%efvs(up,:,:)
factor:        1.0/scyr
load:          1

[temp]
dimensions:    time, level, y1, x1
units:         degree_Celsius
long_name:     ice temperature
data:          data%temper%temp(up,1:data%general%ewn,1:data%general%nsn)
standard_name: land_ice_temperature
load:          1

[tempstag]
dimensions:    time, stagwbndlevel, y1, x1
units:         degree_Celsius
long_name:     ice temperature on staggered vertical levels with boundaries
data:          data%temper%temp(up,1:data%general%ewn,1:data%general%nsn)
standard_name: land_ice_temperature_stag
# hot=0 because we do not want the stag version to be in the hotvars definition.
# The conversion to stag happens if needed in check_for_tempstag.
load:          1

[tempunstag]
dimensions:    time, level, y1, x1
units:         degree_Celsius
long_name:     ice temperature on unstaggered vertical levels
data:          data%temper%tempunstag(up,1:data%general%ewn,1:data%general%nsn)
standard_name: land_ice_temperature_unstag
load:          1

[bpmp]
dimensions:    time, y1, x1
units:         degree_Celsius
long_name:     basal pressure melting point temperature
data:          data%temper%bpmp
standard_name: pressure_melting_point_temperature

[litho_temp]
dimensions:    time, lithoz, y1, x1
units:         degree_Celsius
long_name:     lithosphere temperature
data:          data%lithot%temp
load:          1

[ice_age]
dimensions:    time, staglevel, y1, x1
units:         year
long_name:     ice age
data:          data%geometry%ice_age(up,:,:)
standard_name: land_ice_age
factor:        1/scyr
load:          1

[f_flotation]
dimensions:    time, y1, x1
units:         unitless
long_name:     flotation function
data:          data%geometry%f_flotation
load:          0

[f_ground]
dimensions:    time, y0, x0
units:         unitless [0,1]
long_name:     grounded ice fraction
data:          data%geometry%f_ground
standard_name: grounded_fraction
load:          0

[f_ground_cell]
dimensions:    time, y1, x1
units:         unitless [0,1]
long_name:     grounded ice fraction in cells
data:          data%geometry%f_ground_cell
standard_name: grounded_fraction_cell
load:          0

[sfc_mbal_flux]
dimensions:    time, y1, x1
units:         kg/m2/s
long_name:     surface mass balance flux
data:          data%geometry%sfc_mbal_flux
standard_name: land_ice_surface_specific_mass_balance_flux
average:       1

[basal_mbal_flux]
dimensions:    time, y1, x1
units:         kg/m2/s
long_name:     basal mass balance flux
data:          data%geometry%basal_mbal_flux
standard_name: land_ice_basal_specific_mass_balance_flux
average:       1

[calving_flux]
dimensions:    time, y1, x1
units:         kg/m2/s
long_name:     calving flux
data:          data%geometry%calving_flux
standard_name: land_ice_specific_mass_flux_due_to_calving
average:       1

[gl_flux]
dimensions:    time, y1, x1
units:         kg/m/s
long_name:     grounding line flux
data:          data%geometry%gl_flux
standard_name: land_ice_mass_flux_at_grounding_line
coordinate:    lon lat
average:       1

[gl_flux_east]
dimensions:    time, y1, x1
units:         kg/m/s
long_name:     grounding line flux eastward
data:          data%geometry%gl_flux_east
standard_name: land_ice_mass_flux_at_grounding_line_eastward
coordinate:    lon lat

[gl_flux_north]
dimensions:    time, y1, x1
units:         kg/m/s
long_name:     grounding line flux northward
data:          data%geometry%gl_flux_north
standard_name: land_ice_mass_flux_at_grounding_line_northward
coordinate:    lon lat

[total_gl_flux]
dimensions:    time
units:         kg/s
long_name:     total grounding line flux
data:          data%geometry%total_gl_flux
average:       1

[rho_ice]
dimensions:    time
units:         kg/meter3
long_name:     ice density
data:          rhoi
factor:        noscale
standard_name: rho_ice

[rho_seawater]
dimensions:    time
units:         kg/meter3
long_name:     seawater density
data:          rhoo
factor:        noscale
standard_name: rho_seawater

[gravity]
dimensions:    time
units:         meter/s/s
long_name:     gravitational acceleration
data:          grav
factor:        noscale
standard_name: gravity

[seconds_per_year]
dimensions:    time
units:         s/yr
long_name:     seconds per year
data:          scyr
factor:        noscale
standard_name: seconds_per_year

[ice_specific_heat]
dimensions:    time
units:         J/kg/K
long_name:     ice specific heat 
data:          shci
factor:        noscale
standard_name: ice_specific_heat

[ice_thermal_conductivity]
dimensions:    time
units:         W/(m K)
long_name:     ice thermal conductivity 
data:          coni
factor:        noscale
standard_name: ice_thermal_conductivity

[dissip]
dimensions:   time, level, y1, x1
units:        deg C/yr
long_name:    dissipation rate (W m-3) divided by rhoi Ci
data:         data%temper%dissip(up,:,:)
factor:       scyr
load:         1

[dissipstag]
dimensions:   time, staglevel, y1, x1
units:        deg C/yr
long_name:    dissipation rate (W m-3) divided by rhoi Ci
data:         data%temper%dissip(up,:,:)
factor:       scyr
load:         1

[adv_cfl_dt]
dimensions:    time
units:         years
long_name:     advective CFL maximum time step
data:          data%numerics%adv_cfl_dt

[diff_cfl_dt]
dimensions:    time
units:         years
long_name:     diffusive CFL maximum time step
data:          data%numerics%diff_cfl_dt

[rgi_glacier_id]
dimensions:    time, y1, x1
units:         1
long_name:     input RGI glacier ID
data:          data%glacier%rgi_glacier_id
load:          1

[cism_glacier_id]
dimensions:    time, y1, x1
units:         1
long_name:     CISM-specific glacier ID
data:          data%glacier%cism_glacier_id
load:          1

[cism_glacier_id_init]
dimensions:    time, y1, x1
units:         1
long_name:     initial CISM-specific glacier ID
data:          data%glacier%cism_glacier_id_init
load:          1

[smb_glacier_id]
dimensions:    time, y1, x1
units:         1
long_name:     glacier ID for applying SMB
data:          data%glacier%smb_glacier_id
load:          1

[smb_glacier_id_init]
dimensions:    time, y1, x1
units:         1
long_name:     initial glacier ID for applying SMB
data:          data%glacier%smb_glacier_id_init
load:          1

[cism_to_rgi_glacier_id]
dimensions:    time, glacierid
units:         1
long_name:     RGI glacier ID corresponding to CISM ID
data:          data%glacier%cism_to_rgi_glacier_id
load:          1

[glacier_area_factor]
dimensions:    time, y1, x1
units:         1
long_name:     glacier area scale factor
data:          data%glacier%area_factor
load:          1

[glacier_area]
dimensions:    time, glacierid
units:         m2
long_name:     glacier area
data:          data%glacier%area

[glacier_volume]
dimensions:    time, glacierid
units:         m3
long_name:     glacier volume
data:          data%glacier%volume

[glacier_area_init]
dimensions:    time, glacierid
units:         m2
long_name:     initial glacier area
data:          data%glacier%area_init
load:          1

[glacier_volume_init]
dimensions:    time, glacierid
units:         m3
long_name:     initial glacier volume
data:          data%glacier%volume_init
load:          1

[glacier_mu_star]
dimensions:    time, glacierid
units:         mm w.e./yr/deg
long_name:     glacier SMB coefficient
data:          data%glacier%mu_star
load:          1

[glacier_alpha_snow]
dimensions:    time, glacierid
units:         1
long_name:     glacier snow factor
data:          data%glacier%alpha_snow
load:          1

[glacier_beta_artm]
dimensions:    time, glacierid
units:         degC
long_name:     glacier temperature correction
data:          data%glacier%beta_artm
load:          1

[glacier_smb_obs]
dimensions:    time, glacierid
units:         mm w.e./yr
long_name:     observed glacier-average SMB
data:          data%glacier%smb_obs
load:          1

[glacier_smb]
dimensions:    time, glacierid
units:         mm w.e./yr
long_name:     modeled glacier-average SMB
data:          data%glacier%smb

[glacier_total_area]
dimensions:    time
units:         km2
long_name:     total glacier area
factor:        1.e-06
data:          data%glacier%total_area

[glacier_total_volume]
dimensions:    time
units:         km3
long_name:     total glacier volume
factor:        1.e-09
data:          data%glacier%total_volume

[nglacier_active]
dimensions:    time
units:         1
long_name:     number of active glaciers
data:          data%glacier%nglacier_active
